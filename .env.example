# =============================================================
# .env.example — Copy to .env and fill in your values
# NEVER commit the .env file — only this example template
# =============================================================

# ── NODE IPs (Tailscale) ──────────────────────────────────
NODE01_TAILSCALE_IP=100.x.x.x
NODE02_TAILSCALE_IP=100.x.x.x
NODE03_TAILSCALE_IP=100.x.x.x
NODE04_TAILSCALE_IP=100.x.x.x

# ── NODE IPs (LAN) ────────────────────────────────────────
NODE01_LAN_IP=192.168.x.x
NODE02_LAN_IP=192.168.x.x
NODE03_LAN_IP=192.168.x.x

# ── LiteLLM ───────────────────────────────────────────────
LITELLM_MASTER_KEY=your_litellm_master_key
LITELLM_PORT=4000

# ── LLM API Keys ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── n8n ───────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=your_n8n_encryption_key
N8N_PORT=5678

# ── Immich ────────────────────────────────────────────────
IMMICH_DB_PASSWORD=your_db_password
IMMICH_PORT=2283

# ── Portainer ─────────────────────────────────────────────
PORTAINER_PORT=9443

# ── Tailscale ─────────────────────────────────────────────
TAILSCALE_AUTH_KEY=your_tailscale_auth_key

# ── Backup ────────────────────────────────────────────────
BACKUP_DESTINATION_NODE=NODE01_TAILSCALE_IP
BACKUP_DESTINATION_PATH=/mnt/personal_data/backups
